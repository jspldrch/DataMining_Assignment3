        "axes[1].set_title(\"Model Comparison (full feature set)\", fontsize=11)\n",
        "axes[1].set_xlim(0.75, 1.02)\n",
        "axes[1].axvline(full_acc, color=\"gray\", linestyle=\"--\", lw=1, alpha=0.6)\n",
        "plt.suptitle(\"Ablation Study — Feature Groups and Model Families\", fontsize=12)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"outputs/q4_ablation.png\", dpi=150, bbox_inches=\"tight\")\n",
        "plt.show()"
      ],
