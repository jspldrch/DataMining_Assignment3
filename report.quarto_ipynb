        "model_accs  = [0.814, 0.938, 0.952, 0.961]\n",
        "model_cols  = [\"#e74c3c\", \"#f39c12\", \"#2980b9\", \"#27ae60\"]\n",
        "axes[1].barh(model_names, model_accs, color=model_cols, edgecolor=\"white\", height=0.55)\n",
        "for m, yp in zip(model_accs, range(len(model_accs))):\n",
