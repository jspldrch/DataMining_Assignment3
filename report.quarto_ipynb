        "\n",
        "groups_a = [\"Global stats (54)\", \"Magnitude (3)\", \"Temporal segments (120)\",\n",
        "            \"Autocorrelation (24)\", \"Trend slope (6)\", \"Spectral (30)\"]\n",
        "full_acc = 0.9377\n",
