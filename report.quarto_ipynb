        "cmap    = plt.cm.YlOrRd\n",
        "bcolors = [cmap(d / max(drops) * 0.85 + 0.1) for d in drops]\n",
        "axes[0].barh(groups_a[::-1], drops[::-1], color=bcolors[::-1], edgecolor=\"white\", height=0.6)\n",
