        "axes[0].axvline(0, color=\"black\", lw=0.8)\n",
        "axes[0].set_xlabel(\"Accuracy Drop when Feature Group Removed\")\n",
        "axes[0].set_title(\"Feature Group Importance (leave-one-out)\", fontsize=11)\n",
